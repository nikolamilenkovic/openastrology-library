{
    "name": "openastrology-library",
    "version": "1.0.0",
    "description": "Comprehensive Vedic and Western astrology calculation library powered by Swiss Ephemeris - birth charts, divisional charts, dashas, yogas, aspects, chart patterns, and more",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE-*.txt",
        "LICENSING.md"
    ],
    "scripts": {
        "build": "tsup",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build && npm run test"
    },
    "keywords": [
        "vedic-astrology",
        "jyotish",
        "astrology",
        "birth-chart",
        "horoscope",
        "swiss-ephemeris",
        "planetary-positions",
        "dasha",
        "yoga",
        "ashtakavarga",
        "divisional-charts",
        "nakshatra",
        "zodiac",
        "western-astrology",
        "tropical-astrology",
        "aspects",
        "chart-patterns",
        "chiron",
        "placidus"
    ],
    "author": "Nikola Milenkovic",
    "license": "(AGPL-3.0 OR LGPL-3.0)",
    "repository": {
        "type": "git",
        "url": "https://github.com/nikolamilenkovic/openastrology-library.git"
    },
    "bugs": {
        "url": "https://github.com/nikolamilenkovic/openastrology-library/issues"
    },
    "homepage": "https://github.com/nikolamilenkovic/openastrology-library#readme",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "luxon": "^3.6.1",
        "swisseph": "^0.5.17"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/luxon": "^3.4.2",
        "@types/node": "^20.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "tsup": "^8.0.1",
        "typescript": "^5.9.3"
    }
}
